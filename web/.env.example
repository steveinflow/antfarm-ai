# Firebase configuration for the Docket web app.
#
# These values are injected into the bundle at build time by webpack DefinePlugin
# (see webpack.config.js).  Copy this file to .env and fill in your Firebase
# project's values, or export the variables directly in your shell / CI environment.
#
# ALL six variables are required — the build will produce a broken app if any are
# missing.  The orchestrator sets these from its own config before running webpack.
#
# To set up for local development:
#   1. Copy this file:  cp web/.env.example web/.env
#   2. Fill in the values from your Firebase project's console
#      (Project settings → General → Your apps → Web app → SDK setup and config)
#   3. Run:  npm run build  or  npm start
#
# .env is gitignored — never commit real credentials.

FIREBASE_API_KEY=your-api-key-here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
